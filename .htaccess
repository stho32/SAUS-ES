# Redirect all requests to the Laravel public directory
# This file is only used when the web root points to the repository root
# (e.g., legacy Apache setup). For Docker, the DocumentRoot is public/.

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Verhindere Zugriff auf .git, .env und andere sensible Dateien
    RedirectMatch 403 /\..*$

    # Verhindere direkten Zugriff auf die includes Directory
    RedirectMatch 403 ^/includes/.*$

    # Redirect to public/ for Laravel
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# Sicherheitsheader
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# Zeichensatz
AddDefaultCharset UTF-8

# Komprimierung aktivieren
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/x-javascript application/json
</IfModule>
