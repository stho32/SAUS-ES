# docker-compose liest diese Datei am Repo-Root automatisch.
# Kopiere sie nach `.env` und setze einen eigenen APP_KEY.
#
# APP_KEY erzeugen:
#   docker compose run --rm -e APP_KEY=base64:$(openssl rand -base64 32) app php -r "echo getenv('APP_KEY');"
# oder einfacher auf einem Host mit PHP:
#   php -r "echo 'base64:'.base64_encode(random_bytes(32)).PHP_EOL;"

APP_KEY=
