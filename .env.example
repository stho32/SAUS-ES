APP_NAME=SAUS-ES
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Berlin
APP_URL=http://localhost:8000
APP_LOCALE=de

LOG_CHANNEL=single

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=saus_es
DB_USERNAME=saus_user
DB_PASSWORD=saus_password

SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=file

# SAUS-ES specific
SAUS_MIN_VOTES_REQUIRED=4
SAUS_UPLOAD_PATH=php/uploads/tickets
SAUS_NEWS_UPLOAD_PATH=php/uploads/news

# Public route prefix — deliberately different from admin routes
# so crawlers finding the public pages won't discover the admin tool.
# Change this to match your production URL structure.
SAUS_PUBLIC_ROUTE_PREFIX=public-information
