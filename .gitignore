# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Aider
.aider*

# docker-compose reads this at repo root — never commit it
/.env

# Laravel (inside Source/)
Source/vendor/
Source/node_modules/
Source/.env
Source/.env.backup
Source/.env.production
Source/.env.dusk.local

# Laravel generated
Source/storage/*.key
Source/storage/framework/cache/data/*
Source/storage/framework/sessions/*
Source/storage/framework/views/*
Source/bootstrap/cache/*

# SQLite
Source/database/database.sqlite

# Logs
Source/storage/logs/*.log

# Uploads (files, not directory structure)
Source/uploads/tickets/*
!Source/uploads/tickets/.htaccess
Source/uploads/news/*
!Source/uploads/news/.htaccess

# Dusk
Source/tests/Browser/screenshots/*
!Source/tests/Browser/screenshots/.gitignore
Source/tests/Browser/console/*
!Source/tests/Browser/console/.gitignore
Source/tests/Browser/source/*
!Source/tests/Browser/source/.gitignore

